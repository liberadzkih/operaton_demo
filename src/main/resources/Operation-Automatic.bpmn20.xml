<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_Automatic"
                  targetNamespace="http://camunda.org/schema/1.0/bpmn">
  <bpmn:process id="Operation-Automatic" name="Operation Automatic" isExecutable="true" camunda:historyTimeToLive="P30D">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_Start_Validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Validate" name="Validate Data"
                      camunda:delegateExpression="${validateDataDelegate}">
      <bpmn:incoming>Flow_Start_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_Process</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Process" name="Process Data"
                      camunda:delegateExpression="${processDataDelegate}">
      <bpmn:incoming>Flow_Validate_Process</bpmn:incoming>
      <bpmn:outgoing>Flow_Process_Notify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Notify" name="Send Notification"
                      camunda:delegateExpression="${sendNotificationDelegate}">
      <bpmn:incoming>Flow_Process_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_Notify_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Validate" sourceRef="StartEvent_1" targetRef="Task_Validate" />
    <bpmn:sequenceFlow id="Flow_Validate_Process" sourceRef="Task_Validate" targetRef="Task_Process" />
    <bpmn:sequenceFlow id="Flow_Process_Notify" sourceRef="Task_Process" targetRef="Task_Notify" />
    <bpmn:sequenceFlow id="Flow_Notify_End" sourceRef="Task_Notify" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Operation-Automatic">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="159" y="145" width="23" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Validate_di" bpmnElement="Task_Validate">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Process_di" bpmnElement="Task_Process">
        <dc:Bounds x="400" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Notify_di" bpmnElement="Task_Notify">
        <dc:Bounds x="560" y="80" width="100" height="80" />
