<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:operaton="http://operaton.org/schema/1.0/bpmn" id="Definitions_CurrencyExchange" targetNamespace="http://operaton.org/schema/1.0/bpmn" exporter="Operaton Modeler" exporterVersion="1.2.0-dev">
  <bpmn:process id="Operation-CurrencyExchange" name="Currency Exchange Request" isExecutable="true" operaton:historyTimeToLive="P30D">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_Start_Fetch</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_FetchRate" name="Fetch Exchange Rate" operaton:delegateExpression="${fetchExchangeRateDelegate}">
      <bpmn:incoming>Flow_Start_Fetch</bpmn:incoming>
      <bpmn:outgoing>Flow_Fetch_Review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Review" name="Review Exchange" operaton:assignee="demo">
      <bpmn:extensionElements>
        <operaton:formData>
          <operaton:formField id="rateSummary" label="Exchange details" type="string">
            <operaton:validation>
              <operaton:constraint name="readonly" />
            </operaton:validation>
          </operaton:formField>
          <operaton:formField id="fromCurrency" label="From currency" type="string">
            <operaton:validation>
              <operaton:constraint name="readonly" />
            </operaton:validation>
          </operaton:formField>
          <operaton:formField id="toCurrency" label="To currency" type="string">
            <operaton:validation>
              <operaton:constraint name="readonly" />
            </operaton:validation>
          </operaton:formField>
          <operaton:formField id="rateDate" label="Rate date" type="string">
            <operaton:validation>
              <operaton:constraint name="readonly" />
            </operaton:validation>
          </operaton:formField>
          <operaton:formField id="approved" label="Approve exchange?" type="boolean" defaultValue="false">
            <operaton:validation>
              <operaton:constraint name="required" />
            </operaton:validation>
          </operaton:formField>
        </operaton:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Fetch_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Approved" name="Approved?">
      <bpmn:incoming>Flow_Review_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Notify" name="Confirm Exchange" operaton:delegateExpression="${sendNotificationDelegate}">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Reject" name="Reject Exchange" operaton:delegateExpression="${rejectDelegate}">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Approved" name="Confirmed">
      <bpmn:incoming>Flow_Notify_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Fetch" sourceRef="StartEvent_1" targetRef="Task_FetchRate" />
    <bpmn:sequenceFlow id="Flow_Fetch_Review" sourceRef="Task_FetchRate" targetRef="Task_Review" />
    <bpmn:sequenceFlow id="Flow_Review_Gateway" sourceRef="Task_Review" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_Approved" name="approved" sourceRef="Gateway_Approved" targetRef="Task_Notify">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Rejected" name="rejected" sourceRef="Gateway_Approved" targetRef="Task_Reject">
      <bpmn:conditionExpression xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="bpmn:tFormalExpression">${approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Notify_End" sourceRef="Task_Notify" targetRef="EndEvent_Approved" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Task_Reject" targetRef="EndEvent_Rejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Operation-CurrencyExchange">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="159" y="225" width="23" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FetchRate_di" bpmnElement="Task_FetchRate">
        <dc:Bounds x="240" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Review_di" bpmnElement="Task_Review">
        <dc:Bounds x="400" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Approved_di" bpmnElement="Gateway_Approved" isMarkerVisible="true">
        <dc:Bounds x="555" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="613" y="193" width="53" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Notify_di" bpmnElement="Task_Notify">
        <dc:Bounds x="660" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Reject_di" bpmnElement="Task_Reject">
        <dc:Bounds x="660" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Approved_di" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="822" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="817" y="145" width="47" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="822" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="820" y="325" width="43" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Fetch_di" bpmnElement="Flow_Start_Fetch">
        <di:waypoint x="188" y="200" />
        <di:waypoint x="240" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fetch_Review_di" bpmnElement="Flow_Fetch_Review">
        <di:waypoint x="340" y="200" />
        <di:waypoint x="400" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Review_Gateway_di" bpmnElement="Flow_Review_Gateway">
        <di:waypoint x="500" y="200" />
        <di:waypoint x="555" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approved_di" bpmnElement="Flow_Approved">
        <di:waypoint x="580" y="175" />
        <di:waypoint x="580" y="120" />
        <di:waypoint x="660" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="587" y="103" width="46" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Rejected_di" bpmnElement="Flow_Rejected">
        <di:waypoint x="580" y="225" />
        <di:waypoint x="580" y="300" />
        <di:waypoint x="660" y="300" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="588" y="306" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Notify_End_di" bpmnElement="Flow_Notify_End">
        <di:waypoint x="760" y="120" />
        <di:waypoint x="822" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Reject_End_di" bpmnElement="Flow_Reject_End">
        <di:waypoint x="760" y="300" />
        <di:waypoint x="822" y="300" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
